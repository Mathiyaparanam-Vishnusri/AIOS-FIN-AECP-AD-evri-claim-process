    {
      "parameters": {
        "jsCode": "const outputItems = [];\n\nfor (const item of $input.all()) {\nlet raw = (item.json.output || '').trim();\n\n// Strip JSON markdown fences\nraw = raw.replace(/^`(?:json)?\\s*/i, '').replace(/\\s*`$/i, '').trim();\n\nlet rows;\ntry {\nrows = JSON.parse(raw);\n} catch (e) {\ncontinue;\n}\n\nif (!Array.isArray(rows)) rows = [rows];\n\nfor (const row of rows) {\nif (typeof row !== 'object' || row === null) continue;\n\n```\n// brand_name = Ledsone\nrow.brand_name = 'Ledsone';\n\n// Normalise customer_address\nlet addr = row.customer_address || '';\nif (Array.isArray(addr)) {\n  addr = addr.map(a => String(a).trim()).filter(Boolean).join(', ');\n} else {\n  addr = String(addr)\n    .split('\\n')\n    .map(a => a.trim())\n    .filter(Boolean)\n    .join(', ');\n}\nrow.customer_address = addr;\n\n// Extract UK postcode\nconst postcodeMatch = addr.match(\n  /\\b([A-Z]{1,2}\\d{1,2}[A-Z]?\\s*\\d[A-Z]{2})\\b/i\n);\n\nrow.postal_code = postcodeMatch\n  ? postcodeMatch[1].toUpperCase().trim()\n  : (row.postal_code || '');\n\n// Extract tracking number\nif (!row.tracking_number) {\n  const trackingMatch = String(\n    row.shipment_details || ''\n  ).match(/\\(([^)]+)\\)/);\n\n  if (trackingMatch) {\n    row.tracking_number = trackingMatch[1].trim();\n  }\n}\n\n// Date adjustment\nconst dateStr = String(row.invoice_date || '').trim();\n\nif (dateStr) {\n  let d = null;\n\n  if (/^\\d{4}-\\d{2}-\\d{2}$/.test(dateStr)) {\n    d = new Date(dateStr + 'T00:00:00');\n  } else if (/^\\d{2}\\/\\d{2}\\/\\d{4}$/.test(dateStr)) {\n    const [day, month, year] = dateStr.split('/');\n    d = new Date(`${year}-${month}-${day}T00:00:00`);\n  } else if (/^\\d{2}-\\d{2}-\\d{4}$/.test(dateStr)) {\n    const [day, month, year] = dateStr.split('-');\n    d = new Date(`${year}-${month}-${day}T00:00:00`);\n  } else {\n    d = new Date(dateStr);\n  }\n\n  if (d && !isNaN(d.getTime())) {\n    d.setDate(d.getDate() - 5);\n\n    const yyyy = d.getFullYear();\n    const mm = String(d.getMonth() + 1).padStart(2, '0');\n    const dd = String(d.getDate()).padStart(2, '0');\n\n    row.invoice_date = `${yyyy}-${mm}-${dd}`;\n  }\n}\n\n// Currency detection\nif (!row.currency) {\n  let detected = 'GBP';\n\n  for (const f of [\n    'unit_price',\n    'total_price',\n    'subtotal',\n    'total',\n    'paid'\n  ]) {\n    const v = String(row[f] || '');\n\n    if (v.includes('£')) {\n      detected = 'GBP';\n      break;\n    }\n\n    if (v.includes('$')) {\n      detected = 'USD';\n      break;\n    }\n\n    if (v.includes('€')) {\n      detected = 'EUR';\n      break;\n    }\n  }\n\n  row.currency = detected;\n}\n\n// Numeric conversion\nconst numericFields = [\n  'quantity',\n  'unit_price',\n  'total_price',\n  'subtotal_items',\n  'discount',\n  'subtotal',\n  'vat',\n  'shipping_cost',\n  'total',\n  'paid'\n];\n\nfor (const f of numericFields) {\n  const cleaned = String(row[f] ?? '0')\n    .replace(/[£$€,]/g, '')\n    .trim();\n\n  const parsed = parseFloat(cleaned);\n\n  row[f] = isNaN(parsed) ? 0.0 : parsed;\n}\n\n// Clamp subtotal_items\nrow.subtotal_items = Math.max(\n  40,\n  Math.min(60, row.subtotal_items)\n);\n\n// CSV-safe quoting\nfor (const key of Object.keys(row)) {\n  if (\n    typeof row[key] === 'string' &&\n    /[,\"\\n]/.test(row[key])\n  ) {\n    row[key] =\n      '\"' +\n      row[key].replace(/\"/g, '\"\"') +\n      '\"';\n  }\n}\n\noutputItems.push({\n  json: row\n});\n```\n\n}\n}\n\nreturn outputItems;\n"
      },
